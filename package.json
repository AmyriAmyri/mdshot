{
  "name": "mdshot",
  "version": "0.1.1",
  "description": "",
  "license": "MIT",
  "repository": "pi0/mdshot",
  "bin": {
    "mdshot": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "fonts"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "build": "obuild",
    "dev": "vitest dev",
    "fmt": "automd && oxlint . --fix && oxfmt .",
    "lint": "oxlint . && oxfmt --check .",
    "prepack": "pnpm build",
    "release": "pnpm test && pnpm build && changelogen --release && npm publish && git push --follow-tags",
    "test": "pnpm lint && pnpm typecheck",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "mdshot": "node --watch ./src/cli.ts"
  },
  "dependencies": {
    "@takumi-rs/core": "^0.70.4",
    "md4x": "^0.0.18"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@typescript/native-preview": "latest",
    "automd": "latest",
    "changelogen": "latest",
    "obuild": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "latest"
  },
  "packageManager": "pnpm@10.29.3"
}
